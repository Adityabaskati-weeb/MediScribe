{
  "name": "mediscribe-backend",
  "version": "0.1.0",
  "private": true,
  "description": "MediScribe Node/Express API described in the hackathon roadmap.",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run test:diagnosis && npm run test:integration",
    "test:integration": "ts-node src/tests/integration.test.ts",
    "test:gemma": "ts-node src/tests/gemmaService.test.ts",
    "test:diagnosis": "ts-node src/tests/diagnosis.test.ts",
    "test:unit": "ts-node src/tests/validators.test.ts"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
