    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "overrides": {
    "@react-native-voice/voice": {
      "@expo/config-plugins": "55.0.8"
    }
